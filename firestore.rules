rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogado() {
      return request.auth != null;
    }

    function usuarioAtual() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function isAdmin() {
      return estaLogado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && usuarioAtual().data.perfil == "administrador"
        && usuarioAtual().data.ativo == true;
    }

    function isCozinheiro() {
      return estaLogado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && usuarioAtual().data.perfil == "cozinheiro"
        && usuarioAtual().data.ativo == true;
    }

    function textoValido(campo, minimo, maximo) {
      return campo is string
        && campo.size() >= minimo
        && campo.size() <= maximo;
    }

    function telefoneValido(campo) {
      return campo is string
        && campo.matches('^[0-9]{10,11}$');
    }

    function statusPublicoValido() {
      return request.resource.data.status == "pendente";
    }

    function origemPublicaValida() {
      return request.resource.data.origem == "formulario_publico";
    }

    function camposIntencaoDoacaoValidos() {
      return request.resource.data.keys().hasOnly([
        "protocolo",
        "nomeDoador",
        "contato",
        "contatoOriginal",
        "item",
        "categoria",
        "quantidade",
        "validade",
        "observacao",
        "status",
        "origem",
        "criadoEm",
        "atualizadoEm"
      ]);
    }

    function dadosIntencaoDoacaoValidos() {
      return camposIntencaoDoacaoValidos()
        && textoValido(request.resource.data.protocolo, 12, 30)
        && textoValido(request.resource.data.nomeDoador, 3, 80)
        && telefoneValido(request.resource.data.contato)
        && textoValido(request.resource.data.contatoOriginal, 10, 20)
        && textoValido(request.resource.data.item, 2, 80)
        && textoValido(request.resource.data.categoria, 3, 40)
        && textoValido(request.resource.data.quantidade, 1, 40)
        && statusPublicoValido()
        && origemPublicaValida()
        && request.resource.data.criadoEm == request.time
        && request.resource.data.atualizadoEm == request.time;
    }

    match /intencoes_doacao/{id} {
      allow create: if dadosIntencaoDoacaoValidos()
        && request.resource.data.protocolo == id
        && !exists(/databases/$(database)/documents/intencoes_doacao/$(id));

      allow read: if isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /usuarios/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow create, update, delete: if isAdmin();
    }

    match /alimentos/{alimentoId} {
      allow read: if estaLogado();
      allow create, update: if isAdmin() || isCozinheiro();
      allow delete: if isAdmin();
    }

    match /movimentacoes/{movimentacaoId} {
      allow read: if estaLogado();
      allow create: if isAdmin() || isCozinheiro();
      allow update, delete: if isAdmin();
    }

    match /doacoes/{doacaoId} {
      allow read: if estaLogado();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /doadores/{doadorId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}